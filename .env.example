# Hive Pal Environment Configuration
# Copy this file to .env and update with your values

# ====================
# Required Configuration
# ====================

# Backend Configuration
DATABASE_URL=postgres://postgres:postgres@postgres:5432/beekeeper
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme123  # IMPORTANT: Change this in production!

# Authentication (Better Auth)
BETTER_AUTH_SECRET=replace_me_with_random_string  # 32+ chars; generate with: openssl rand -base64 32
BETTER_AUTH_URL=http://backend:3000  # Backend public base URL where /api/auth/* is served
# PASSKEY_RP_ID=localhost  # WebAuthn relying-party ID (optional)
# COOKIE_DOMAIN=.yourdomain.com  # Set in prod when frontend and backend share a parent domain
# BETTER_AUTH_SECURE_COOKIES=false  # Set to false when serving over plain http (defaults to true only for https:// BETTER_AUTH_URL); Secure cookies are dropped over http on non-localhost hosts

# API URLs
API_URL=http://backend:3000  # Internal API URL (used by frontend container)
# HiveScale was renamed to HiveHub. Prefer HIVEHUB_*; the legacy HIVESCALE_*
# names below are still accepted as a fallback if you set those instead.
HIVEHUB_API_BASE_URL=http://hivehub:8000  # Internal HiveHub API URL used by HivePal backend
HIVEHUB_SERVICE_API_KEY=change-me-hivepal-to-hivehub-service-key
# HIVESCALE_API_BASE_URL=http://hivehub:8000  # Legacy alias (still supported)
# HIVESCALE_SERVICE_API_KEY=change-me-hivepal-to-hivehub-service-key
FRONTEND_URL=https://yourdomain.com  # Public frontend URL (used in emails)

# Frontend Configuration
VITE_API_URL=https://api.yourdomain.com  # Public API URL (used by browser)
ALLOWED_ORIGINS=http://localhost:8080,https://yourdomain.com,http://localhost:5173

# ====================
# Optional Configuration
# ====================

# Email Configuration (Required for password reset functionality)
# Uncomment and configure if you want email features
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-specific-password
# SMTP_SECURE=false  # true for port 465 (SSL), false for port 587 (TLS)
# SMTP_REJECT_UNAUTHORIZED=false  # Set to true for production with valid certificates
# FROM_EMAIL=noreply@yourdomain.com

# Error Tracking (Optional)
# Configure Sentry for production error monitoring
# SENTRY_DSN=https://your-backend-sentry-dsn@sentry.io/project-id
# SENTRY_ENVIRONMENT=production
# VITE_SENTRY_DSN=https://your-frontend-sentry-dsn@sentry.io/project-id
# VITE_SENTRY_ENVIRONMENT=production

# ====================
# Notes
# ====================
# 1. SMTP configuration is optional but required for password reset emails
# 2. For Gmail, use an App Password, not your regular password
# 3. Database data is persisted in /data/hive-pal-data/postgres
# 4. The admin account is created automatically on first startup
# 5. Ensure all URLs match your domain configuration when deploying
