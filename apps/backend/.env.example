ADMIN_EMAIL=admin@example.com
# Plaintext password for the initial admin user; better-auth hashes it on first seed.
ADMIN_PASSWORD=changeme-in-production
JWT_SECRET=your_jwt_secret
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/beekeeper?schema=public"
ALLOWED_ORIGINS=http://localhost:5173

# Better Auth
# BETTER_AUTH_SECRET: random 32+ char string used to sign sessions/cookies.
#   Generate with: openssl rand -base64 32
# BETTER_AUTH_URL: backend's public base URL (where /api/auth/* is served).
# PASSKEY_RP_ID: WebAuthn relying-party ID (optional, defaults to 'localhost').
# COOKIE_DOMAIN: optional, set in prod when frontend and backend are on different
#   subdomains of the same parent domain.
# BETTER_AUTH_SECURE_COOKIES: optional override for the cookie `Secure` flag.
#   Defaults to true only when BETTER_AUTH_URL is https://. Set to "false" when
#   serving over plain http (e.g. a LAN host/IP behind a TLS-less proxy) —
#   browsers drop Secure cookies over http on any host except localhost, which
#   silently breaks login.
BETTER_AUTH_SECRET=replace_me_with_random_string
BETTER_AUTH_URL=http://localhost:3000
# PASSKEY_RP_ID=localhost
# COOKIE_DOMAIN=.hivepal.app
# BETTER_AUTH_SECURE_COOKIES=false

# Email Configuration (Optional)
# The system will automatically select the first configured provider:
# 1. Resend (if RESEND_API_KEY is provided)
# 2. SMTP (if SMTP_HOST, SMTP_USER, and SMTP_PASS are provided)
# 3. Disabled (if no provider is configured)

# Force a specific provider (optional): resend, smtp, or none
# MAIL_PROVIDER=resend

# Resend Configuration
RESEND_API_KEY=your_resend_api_key

# SMTP Configuration
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_REJECT_UNAUTHORIZED=true

# Common Email Settings
FROM_EMAIL=noreply@divepal.app
FRONTEND_URL=http://localhost:5173

# Sentry Configuration (Optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Storage Configuration
# STORAGE_TYPE: 's3' (default) or 'local'
# STORAGE_TYPE=local
# STORAGE_LOCAL_PATH=/data/uploads     # Directory for local file storage

# S3-Compatible Storage Configuration (for audio recordings)
# Use MinIO for local development: docker compose up -d minio
# Then access MinIO console at http://localhost:9001 to create a bucket
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=hivepal-audio
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
# AUDIO_MAX_FILE_SIZE=52428800  # 50MB default

# AI Processing Mode
# AI_PROCESSING_MODE: 'push' (default — call hivepal-ai), 'pull' (wait for
# remote workers via /api/worker/...), or 'auto' (pull preferred, falls back
# to push after AI_PULL_FALLBACK_MINUTES).
# AI_PROCESSING_MODE=push
# AI_PULL_FALLBACK_MINUTES=10
# WORKER_JOB_LEASE_MS=300000   # 5 min — lease workers get when claiming a job

# Push-mode AI service (hivepal-ai)
# AI_SERVICE_BASE_URL=http://hivepal-ai:8008
# AI_API_KEY=
# HiveHub bridge (separate FastAPI backend, formerly HiveScale).
# Prefer HIVEHUB_*; the legacy HIVESCALE_* names are still accepted as a fallback.
HIVEHUB_API_BASE_URL=http://localhost:8000
HIVEHUB_SERVICE_API_KEY=change-me-hivepal-to-hivehub-service-key
# HIVESCALE_API_BASE_URL=http://localhost:8000  # Legacy alias (still supported)
# HIVESCALE_SERVICE_API_KEY=change-me-hivepal-to-hivehub-service-key
