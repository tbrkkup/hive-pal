generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  importFileExtension = "js"
  moduleFormat        = "cjs"
}

datasource db {
  provider = "postgresql"
  // url      = env("DATABASE_URL")
}

model User {
  id                     String                 @id @default(uuid())
  email                  String                 @unique
  emailVerified          Boolean                @default(false)
  name                   String?
  image                  String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  lastLoginAt            DateTime?
  apiaries               Apiary[]
  role                   Role                   @default(USER)
  passwordChangeRequired Boolean                @default(false)
  equipmentItems         EquipmentItem[]
  equipmentMultiplier    EquipmentMultiplier?
  preferences            Json?                  // JSON field for user preferences
  feedbacks              Feedback[]
  frameSizes             FrameSize[]
  shareLinks             ShareLink[]
  apiaryMemberships      ApiaryMember[]
  createdInspections     Inspection[]           @relation("InspectionCreator")
  createdActions         Action[]               @relation("ActionCreator")
  createdQuickChecks     QuickCheck[]           @relation("QuickCheckCreator")
  createdWorkerTokens    WorkerToken[]          @relation("WorkerTokenCreator")

  // Better Auth relations
  sessions               Session[]
  accounts               Account[]
  passkeys               Passkey[]

  // Better Auth admin plugin fields
  banned                 Boolean?               @default(false)
  banReason              String?
  banExpires             DateTime?

  // GDPR consent fields
  privacyPolicyConsent   Boolean                @default(false)
  privacyConsentTimestamp DateTime?
  newsletterConsent      Boolean                @default(false)
  newsletterConsentTimestamp DateTime?
}

model Session {
  id             String   @id
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token          String   @unique
  expiresAt      DateTime
  ipAddress      String?
  userAgent      String?
  impersonatedBy String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([token])
}

model Account {
  id                    String    @id
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  password              String?
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  idToken               String?
  scope                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@unique([providerId, accountId])
  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Passkey {
  id           String   @id
  name         String?
  publicKey    String
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentialID String   @unique
  counter      Int
  deviceType   String
  backedUp     Boolean
  transports   String?
  aaguid       String?
  createdAt    DateTime @default(now())

  @@index([userId])
}

enum Role {
  USER
  ADMIN
}

enum ApiaryRole {
  OWNER
  EDITOR
  VIEWER
}

enum MembershipStatus {
  PENDING
  ACTIVE
  REJECTED
}

model Apiary {
  id               String            @id @default(uuid())
  name             String
  location         String?
  latitude         Float?
  longitude        Float?
  notes            String?
  hives                 Hive[]
  harvests              Harvest[]
  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                String
  weather               Weather[]
  weatherHourlyForecasts WeatherHourlyForecast[]
  weatherForecasts      WeatherForecast[]
  batchInspections      BatchInspection[]
  quickChecks           QuickCheck[]
  photos                Photo[]
  documents             Document[]
  featurePhotoId        String?             @unique
  featurePhoto          Photo?              @relation("ApiaryFeaturePhoto", fields: [featurePhotoId], references: [id], onDelete: SetNull)
  members               ApiaryMember[]
  invites               ApiaryInvite[]
  settings              Json?
  apiKeys               ApiaryApiKey[]
  assistantThreads      AssistantThread[]
  todos                 Todo[]

  // Create index for quick lookup by userId - used in authorization checks
  @@index([userId])
}

model Hive {
  id               String       @id @default(uuid())
  name             String
  notes            String?
  apiaryId         String?
  apiary           Apiary?      @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  status           HiveStatus   @default(ACTIVE)
  installationDate DateTime?
  positionRow      Int?         // Row position in apiary layout (0-based)
  positionCol      Int?         // Column position within row (0-based)
  settings         Json?        // JSON field for hive-specific settings (feeding, inspection frequency, etc.)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt @default(now())
  queens           Queen[]
  boxes            Box[]
  inspections      Inspection[]
  actions          Action[]
  harvestHives     HarvestHive[]
  alerts           Alert[]
  batchInspectionHives BatchInspectionHive[]
  quickChecks          QuickCheck[]
  queenMovementsFrom   QueenMovement[] @relation("MovementFromHive")
  queenMovementsTo     QueenMovement[] @relation("MovementToHive")
  photos               Photo[]
  documents            Document[]
  featurePhotoId       String?      @unique
  featurePhoto         Photo?       @relation("HiveFeaturePhoto", fields: [featurePhotoId], references: [id], onDelete: SetNull)
  measurements         Measurement[]
  assistantThreads     AssistantThread[]
  todos                Todo[]

  // Provenance: if this hive was created by splitting another colony, the source
  // (mother) hive. Optional origin marker, NOT an ongoing biological lineage.
  parentHiveId         String?
  parentHive           Hive?        @relation("HiveSplit", fields: [parentHiveId], references: [id], onDelete: SetNull)
  offspring            Hive[]       @relation("HiveSplit")

  // Create index for quick lookup by apiaryId - used in authorization checks
  @@index([apiaryId])
  // Create index for position-based queries within an apiary
  @@index([apiaryId, positionRow, positionCol])
  @@index([parentHiveId])
}

model Measurement {
  id         String   @id @default(uuid())
  hiveId     String
  hive       Hive     @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  metric     String
  value      Float
  unit       String?
  recordedAt DateTime
  source     String?
  createdAt  DateTime @default(now())

  // Optional position of the reading within the hive. Used for manually captured
  // weights (e.g. a "Kippprobe" edge-lift with a hook scale):
  //   boxId = null -> measured at the base / whole hive lifted from the bottom
  //   side  = null -> whole/total weight (no specific edge)
  boxId String?
  box   Box?             @relation(fields: [boxId], references: [id], onDelete: SetNull)
  side  MeasurementSide?

  // Optional link to the inspection during which the reading was captured.
  // Readings captured in an inspection are removed with it (Cascade).
  inspectionId String?
  inspection   Inspection? @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([hiveId, recordedAt])
  @@index([hiveId, metric, recordedAt])
  @@index([hiveId, metric, boxId, side, recordedAt])
  @@index([boxId])
  @@index([inspectionId])
}

// Edge of the hive where a manual weight reading (Kippprobe) was taken.
// FRONT is the entrance / Flugloch side. Null means a whole-hive weighing.
enum MeasurementSide {
  FRONT
  BACK
  LEFT
  RIGHT
}

model Todo {
  id          String    @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime?
  completed   Boolean   @default(false)
  apiaryId    String
  apiary      Apiary    @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  hiveId      String?
  hive        Hive?     @relation(fields: [hiveId], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([apiaryId])
  @@index([hiveId])
}

model ApiaryApiKey {
  id              String    @id @default(uuid())
  apiaryId        String
  apiary          Apiary    @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  name            String
  keyHash         String    @unique
  prefix          String
  lastUsedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  createdByUserId String?

  @@index([apiaryId])
}

model Box {
  id            String      @id @default(uuid())
  hiveId        String
  hive          Hive        @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  position      Int // Position from bottom up
  frameCount    Int // Number of frames in this box
  maxFrameCount Int         @default(10) // Maximum number of frames the box can hold
  hasExcluder   Boolean     @default(false) // Whether there's a queen excluder above this box
  type          BoxType // BROOD, HONEY, etc.
  variant       BoxVariant? // LANGSTROTH_DEEP, LANGSTROTH_SHALLOW, etc.
  frameSizeId   String?
  frameSize     FrameSize?  @relation(fields: [frameSizeId], references: [id], onDelete: SetNull)
  color         String? // Hex color code for visual representation
  lastSanitized DateTime? // When this box position was last replaced with a sanitized box
  addedAt       DateTime    @default(now()) // When this physical/logical box was added to the hive
  winterized    Boolean     @default(false) // Whether this box is prepared for winter
  measurements  Measurement[]

  @@index([hiveId])
  @@index([hiveId, position]) // For looking up boxes by position in a hive
}

model Queen {
  id          String      @id @default(uuid())
  hiveId      String?
  hive        Hive?       @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  name        String?
  marking     String?
  color       String?
  year        Int?
  source      String?
  status      QueenStatus @default(ACTIVE)
  installedAt DateTime?
  replacedAt  DateTime?
  movements   QueenMovement[]

  // Create index for quick lookup by hiveId - used in authorization checks
  @@index([hiveId])
}

model QueenMovement {
  id         String    @id @default(uuid())
  queenId    String
  queen      Queen     @relation(fields: [queenId], references: [id], onDelete: Cascade)
  fromHiveId String?
  fromHive   Hive?     @relation("MovementFromHive", fields: [fromHiveId], references: [id], onDelete: SetNull)
  toHiveId   String?
  toHive     Hive?     @relation("MovementToHive", fields: [toHiveId], references: [id], onDelete: SetNull)
  movedAt    DateTime  @default(now())
  reason     String?
  notes      String?
  createdAt  DateTime  @default(now())

  @@index([queenId])
  @@index([fromHiveId])
  @@index([toHiveId])
}

model Inspection {
  id                String             @id @default(uuid())
  hiveId            String
  hive              Hive               @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  date              DateTime
  isAllDay          Boolean            @default(true)
  notes             InspectionNote[]
  temperature       Float?
  weatherConditions String?
  observations      Observation[]
  actions           Action[]
  status            InspectionStatus @default(COMPLETED)
  batchInspectionHive BatchInspectionHive?
  audioRecordings   InspectionAudio[]
  measurements      Measurement[]
  photos            Photo[]
  createdByUserId   String?
  createdByUser     User?            @relation("InspectionCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  // Persisted scores (calculated from observations, or user-overridden)
  overallScore      Float?
  populationScore   Float?
  storesScore       Float?
  queenScore        Float?
  scoreWarnings     String?
  scoreConfidence   Float?

  // Create index for quick lookup by hiveId - used in authorization checks
  @@index([hiveId])
  // Create index for date-based queries
  @@index([date])
}

enum InspectionStatus {
  SCHEDULED
  OVERDUE
  COMPLETED
  CANCELLED
}

model InspectionNote {
  id           String     @id @default(uuid())
  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  text         String

  @@index([inspectionId])
}

// Audio recordings attached to inspections for voice notes during hive visits
model InspectionAudio {
  id            String              @id @default(uuid())
  inspectionId  String
  inspection    Inspection          @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  // Storage metadata
  storageKey    String              // S3 key: "audio/{inspectionId}/{id}.webm"
  fileName      String              // Original filename for display
  mimeType      String              // "audio/webm", "audio/mp3"
  fileSize      Int                 // Size in bytes
  duration      Float?              // Duration in seconds (optional)

  // Transcription stage (audio -> text)
  transcription              String?             @db.Text
  transcriptionStatus        TranscriptionStatus @default(NONE)
  transcriptionError         String?             @db.Text
  transcriptionClaimedAt     DateTime?
  transcriptionLeaseUntil    DateTime?
  transcriptionWorkerTokenId String?
  transcriptionRetries       Int                 @default(0)

  // Analysis stage (text -> structured JSON)
  analysisStatus        TranscriptionStatus @default(NONE)
  analysisResult        Json?
  analysisError         String?             @db.Text
  analysisCompletedAt   DateTime?
  analysisClaimedAt     DateTime?
  analysisLeaseUntil    DateTime?
  analysisWorkerTokenId String?
  analysisRetries       Int                 @default(0)

  createdAt     DateTime            @default(now())

  @@index([inspectionId])
  @@index([transcriptionStatus])
  @@index([analysisStatus])
}

enum TranscriptionStatus {
  NONE        // No transcription requested
  PENDING     // Queued for transcription
  PROCESSING  // Currently being transcribed
  COMPLETED   // Transcription available
  FAILED      // Transcription failed
}

model Observation {
  id           String     @id @default(uuid())
  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  type         String // BROOD_PATTERN, QUEEN_SEEN, DISEASE_SIGNS etc.
  numericValue Float? // For numerical observations
  textValue    String? // For text-based observations
  booleanValue Boolean? // For boolean observations
  notes        String? // Additional notes about the observation

  @@index([inspectionId])
  @@index([type, inspectionId]) // For looking up specific observation types
}

model Action {
  id           String     @id @default(uuid())
  hiveId       String?
  hive         Hive?      @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  inspectionId String?
  inspection   Inspection? @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  harvestId    String?    // Link to harvest if action from harvest
  harvest      Harvest?   @relation(fields: [harvestId], references: [id], onDelete: Cascade)
  type         ActionType // FEEDING, TREATMENT, HARVEST etc.
  notes        String? // Description of the action taken
  date         DateTime   @default(now()) // Date when action was performed

  feedingAction   FeedingAction?
  treatmentAction TreatmentAction?
  frameAction     FrameAction?
  harvestAction   HarvestAction?
  boxConfigurationAction BoxConfigurationAction?
  maintenanceAction MaintenanceAction?
  statusChangeAction StatusChangeAction?
  splitAction     SplitAction?
  createdByUserId String?
  createdByUser   User?      @relation("ActionCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([hiveId])
  @@index([inspectionId])
  @@index([harvestId])
  @@index([type, hiveId]) // For looking up specific action types
  @@index([date]) // For date-based queries
}

model FeedingAction {
  id            String  @id @default(uuid())
  actionId      String  @unique
  action        Action  @relation(fields: [actionId], references: [id], onDelete: Cascade)
  feedType      String // Sugar Syrup, Honey, Pollen Sub, Candy
  amount        Float // Numeric amount
  unit          String // liters, quarts, gallons, kg, lb
  concentration String? // 1:1, 2:1, etc.
}

// Treatment-specific details
model TreatmentAction {
  id       String  @id @default(uuid())
  actionId String  @unique
  action   Action  @relation(fields: [actionId], references: [id], onDelete: Cascade)
  product  String // Apivar, Formic Pro, etc.
  quantity Float? // Numeric quantity (optional for some treatments like fumigation)
  unit     String // pcs, ml, g
  duration String? // 7 days, 14 days, etc.
}

// Frame-specific details
model FrameAction {
  id       String @id @default(uuid())
  actionId String @unique
  action   Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  quantity Int // number added/removed (positive = added, negative = removed)
}

// Harvest-specific details
model HarvestAction {
  id       String @id @default(uuid())
  actionId String @unique
  action   Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  amount   Float  // kg of honey harvested from this hive
  unit     String @default("kg") // Unit of measurement
}

// Box configuration change details
model BoxConfigurationAction {
  id            String @id @default(uuid())
  actionId      String @unique
  action        Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  boxesAdded    Int    @default(0) // Number of boxes added
  boxesRemoved  Int    @default(0) // Number of boxes removed
  framesAdded   Int    @default(0) // Total number of frames added
  framesRemoved Int    @default(0) // Total number of frames removed
  totalBoxes    Int    // Total boxes after the change
  totalFrames   Int    // Total frames after the change
  boxes         Json?  // Per-box summary: [{type, frameCount}]
}

model MaintenanceAction {
  id        String @id @default(uuid())
  actionId  String @unique
  action    Action @relation(fields: [actionId], references: [id], onDelete: Cascade)
  component String // BOX, BOTTOM_BOARD, COVER
  status    String // CLEANED, REPLACED
}

// Hive status change details (e.g. ACTIVE -> DEAD). Recorded as an action so the
// change lives in the existing timeline/history without a separate audit table.
model StatusChangeAction {
  id         String      @id @default(uuid())
  actionId   String      @unique
  action     Action      @relation(fields: [actionId], references: [id], onDelete: Cascade)
  fromStatus HiveStatus? // Previous status (null if unknown)
  toStatus   HiveStatus  // New status
}

// Colony split (Volksteilung / Ableger) details. A split writes a matched PAIR of
// SPLIT actions sharing one splitId: one on the source (mother) hive and one on
// the new (daughter) hive. Recorded on the timeline; no separate lifecycle entity.
model SplitAction {
  id                String  @id @default(uuid())
  actionId          String  @unique
  action            Action  @relation(fields: [actionId], references: [id], onDelete: Cascade)
  splitId           String  // Groups the source-side and new-side entries of one split
  role              String  // 'SOURCE' | 'NEW'
  counterpartHiveId String? // The other hive in this split (null-safe if it is later deleted)
  framesMoved       Int     // Number of (brood) frames moved from mother to daughter
  queenDisposition  String  // 'STAYED_WITH_SOURCE' | 'MOVED_TO_NEW' | 'NEW_IS_QUEENLESS'

  @@index([splitId])
}

// Harvest tracking
model Harvest {
  id              String         @id @default(uuid())
  apiaryId        String
  apiary          Apiary         @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  date            DateTime
  status          HarvestStatus  @default(DRAFT)
  totalWeight     Float?         // amount of honey extracted
  totalWeightUnit String         @default("kg") // Unit for totalWeight
  notes           String?
  harvestHives    HarvestHive[]
  actions         Action[]       // Actions created when harvest is finalized
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([apiaryId])
  @@index([date])
  @@index([status])
}

model HarvestHive {
  id               String   @id @default(uuid())
  harvestId        String
  harvest          Harvest  @relation(fields: [harvestId], references: [id], onDelete: Cascade)
  hiveId           String
  hive             Hive     @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  framesTaken      Int      // Number of frames harvested from this hive
  honeyAmount      Float?   // Calculated amount after weight entry
  honeyAmountUnit  String   @default("kg") // Unit for honeyAmount
  honeyPercentage  Float?   // Percentage of total harvest

  @@unique([harvestId, hiveId]) // Prevent duplicate hive entries in same harvest
  @@index([harvestId])
  @@index([hiveId])
}

enum HiveStatus {
  ACTIVE
  INACTIVE
  DEAD
  SOLD
  UNKNOWN
  ARCHIVED
}

enum QueenStatus {
  ACTIVE
  REPLACED
  DEAD
  UNKNOWN
}

enum BoxType {
  BROOD // Brood box
  HONEY // Honey super
  FEEDER // Feeder box
}

enum BoxVariant {
  LANGSTROTH_DEEP // Standard Langstroth deep box (9 5/8")
  LANGSTROTH_MEDIUM // Standard Langstroth medium box (6 5/8")
  LANGSTROTH_SHALLOW // Standard Langstroth shallow box (5 11/16")
  B_DEEP // B-hive deep box
  B_SHALLOW // B-hive shallow box
  DADANT // Dadant box
  NATIONAL_DEEP // British National deep
  NATIONAL_SHALLOW // British National shallow
  WARRE // Warré hive box
  TOP_BAR // Top bar hive
  CUSTOM // Custom size
}

enum ActionType {
  FEEDING
  TREATMENT
  FRAME
  HARVEST
  BOX_CONFIGURATION
  MAINTENANCE
  NOTE
  STATUS_CHANGE
  SPLIT
  OTHER
}

enum HarvestStatus {
  DRAFT       // Initial state - selecting hives/frames
  IN_PROGRESS // Extraction ongoing - can set weight
  COMPLETED   // Finalized - actions created, read-only
}

// Weather condition simplified categories
enum WeatherCondition {
  CLEAR
  PARTLY_CLOUDY
  OVERCAST
  FOG
  DRIZZLE
  RAIN
  SNOW
}

// Historical weather data for apiaries (stored hourly)
model Weather {
  id          String            @id @default(uuid())
  apiaryId    String
  apiary      Apiary            @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  timestamp   DateTime          // When the weather data is for (hourly)
  fetchedAt   DateTime          @default(now()) // When we fetched this data
  condition   WeatherCondition
  temperature Float             // in Celsius
  feelsLike   Float             // in Celsius
  humidity    Int               // percentage
  windSpeed   Float             // in km/h
  
  @@unique([apiaryId, timestamp]) // Prevent duplicate entries for same apiary and time
  @@index([apiaryId])
  @@index([timestamp])
  @@index([apiaryId, timestamp])
}

// Hourly weather forecast for the next 5 hours
model WeatherHourlyForecast {
  id          String            @id @default(uuid())
  apiaryId    String
  apiary      Apiary            @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  timestamp   DateTime          // The hour this forecast is for
  fetchedAt   DateTime          @default(now()) // When we fetched this data
  condition   WeatherCondition
  temperature Float             // in Celsius
  feelsLike   Float             // in Celsius
  humidity    Int               // percentage
  windSpeed   Float             // in km/h
  
  @@unique([apiaryId, timestamp]) // Prevent duplicate entries for same apiary and time
  @@index([apiaryId])
  @@index([timestamp])
  @@index([apiaryId, timestamp])
}

// Daily weather forecast for the next 5 days
model WeatherForecast {
  id             String            @id @default(uuid())
  apiaryId       String
  apiary         Apiary            @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  date           DateTime          // The date this forecast is for
  fetchedAt      DateTime          @default(now()) // When we fetched this data
  condition      WeatherCondition
  temperatureMin Float             // in Celsius
  temperatureMax Float             // in Celsius
  humidity       Int               // percentage
  windSpeed      Float             // in km/h
  
  @@unique([apiaryId, date]) // Prevent duplicate entries for same apiary and date
  @@index([apiaryId])
  @@index([date])
  @@index([apiaryId, date])
}

// Log of weather API fetches (used for admin metrics)
model WeatherFetchLog {
  id        String   @id @default(uuid())
  endpoint  String   // 'hourly' or 'daily'
  outcome   String   // 'success' or 'error'
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// Alert system for hive management notifications
model Alert {
  id        String        @id @default(uuid())
  hiveId    String?       // Optional - alerts can be hive-specific or general
  hive      Hive?         @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  type      String        // e.g., "inspection_overdue", "feeding_required", etc.
  message   String        // Human-readable alert message
  severity  AlertSeverity // LOW, MEDIUM, HIGH
  status    AlertStatus   @default(ACTIVE) // ACTIVE, DISMISSED, RESOLVED, SUPERSEDED
  metadata  Json?         // Additional checker-specific data
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([hiveId])
  @@index([type])
  @@index([status])
  @@index([severity])
  @@index([hiveId, type, status]) // Composite index for efficient alert queries
  @@index([createdAt])
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
}

enum AlertStatus {
  ACTIVE      // Alert is currently relevant
  DISMISSED   // User has dismissed the alert
  RESOLVED    // Issue has been resolved
  SUPERSEDED  // Alert replaced by newer alert with different priority
}

// Equipment item configuration for each user
model EquipmentItem {
  id                String              @id @default(uuid())
  userId            String
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemId            String              // e.g., "DEEP_BOX", "SHALLOW_BOX", "FRAMES", "SUGAR", custom IDs
  name              String?             // Display name (optional for custom items)
  enabled           Boolean             @default(true)
  perHive           Float               @default(0) // Amount per hive (for standard calculations)
  extra             Float               @default(0) // Extra inventory on hand (storage)
  inExtraction      Float               @default(0) // Supers currently in extraction
  damaged           Float               @default(0) // Damaged items out of service
  neededOverride    Float?              // Manual override for needed amount (null = use calculation)
  category          EquipmentCategory
  scope             EquipmentScope      @default(PER_HIVE)
  unit              String              @default("pieces") // "pieces", "kg", "liters", etc.
  isCustom          Boolean             @default(false) // Whether this is a custom item
  displayOrder      Int                 @default(999)
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@unique([userId, itemId])
  @@index([userId])
  @@index([userId, category])
}

// Planning multiplier for equipment calculations
model EquipmentMultiplier {
  id                String              @id @default(uuid())
  userId            String              @unique
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetHives       Int                 @default(0) // Target number of hives to plan for (0 = use current)

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

enum EquipmentCategory {
  BOXES           // Deep boxes, shallow boxes
  HIVE_PARTS      // Bottoms, covers, excluders
  FRAMES          // All frame types
  FEEDING         // Feeders, sugar, syrup
  CONSUMABLES     // Treatment, foundation, etc.
  TOOLS           // Hive tools, smokers, etc.
  PROTECTIVE      // Suits, gloves, veils
  EXTRACTION      // Extractors, uncapping tools
  CUSTOM          // User-defined categories
}

enum EquipmentScope {
  PER_HIVE  // Scales with hive count
  SHARED    // Fixed regardless of hive count
}

// Frame size catalog (shared across all users)
model FrameSize {
  id              String          @id @default(uuid())
  name            String          @unique
  width           Float           // mm
  height          Float           // mm
  depth           Float           // mm
  isBuiltIn       Boolean         @default(false)  // true = system preset
  status          FrameSizeStatus @default(PENDING)
  createdByUserId String?
  createdByUser   User?           @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  boxes           Box[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@index([createdByUserId])
}

enum FrameSizeStatus {
  PENDING   // User-contributed, awaiting admin approval
  APPROVED  // Visible to all users
  REJECTED  // Admin rejected
}

// Feedback system for user suggestions, bug reports, etc.
model Feedback {
  id          String         @id @default(uuid())
  userId      String?        // Optional - allows anonymous feedback
  user        User?          @relation(fields: [userId], references: [id])
  email       String?        // Optional email for contact
  type        FeedbackType   // BUG, SUGGESTION, OTHER
  subject     String
  message     String         @db.Text
  status      FeedbackStatus @default(NEW)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

enum FeedbackType {
  BUG
  SUGGESTION
  OTHER
}

enum FeedbackStatus {
  NEW
  REVIEWED
  RESOLVED
}

// Batch inspection management
model BatchInspection {
  id          String                 @id @default(uuid())
  name        String                 // e.g., "Spring 2025 Inspection"
  apiaryId    String
  apiary      Apiary                 @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  status      BatchInspectionStatus  @default(DRAFT)
  startedAt   DateTime?              // When batch inspection was started
  completedAt DateTime?              // When batch inspection was completed
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  hives       BatchInspectionHive[]

  @@index([apiaryId])
  @@index([status])
  @@index([apiaryId, status])
}

// Individual hive entries within a batch inspection
model BatchInspectionHive {
  id                 String           @id @default(uuid())
  batchInspectionId  String
  batchInspection    BatchInspection  @relation(fields: [batchInspectionId], references: [id], onDelete: Cascade)
  hiveId             String
  hive               Hive             @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  order              Int              // Position in inspection queue (0-based)
  status             BatchHiveStatus  @default(PENDING)
  inspectionId       String?          @unique
  inspection         Inspection?      @relation(fields: [inspectionId], references: [id], onDelete: SetNull)
  completedAt        DateTime?        // When this hive's inspection was completed
  skippedCount       Int              @default(0) // Number of times this hive was skipped

  @@unique([batchInspectionId, hiveId]) // Can't add same hive twice to a batch
  @@index([batchInspectionId])
  @@index([batchInspectionId, order])
  @@index([batchInspectionId, status])
}

enum BatchInspectionStatus {
  DRAFT        // Initial state - hives can be added/removed/reordered
  IN_PROGRESS  // Batch inspection is active
  COMPLETED    // All hives inspected
  CANCELLED    // Batch cancelled
}

enum BatchHiveStatus {
  PENDING    // Not yet inspected
  COMPLETED  // Inspection completed
  CANCELLED  // Hive removed from batch
}

// Quick check - lightweight structured observation for a hive or apiary
model QuickCheck {
  id        String           @id @default(uuid())
  hiveId    String?
  hive      Hive?            @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  apiaryId  String
  apiary    Apiary           @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  date      DateTime         @default(now())
  note      String?          @db.Text
  tags      String[]         // reuses additionalObservation + reminderObservation values
  photos          QuickCheckPhoto[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdByUserId String?
  createdByUser   User?            @relation("QuickCheckCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([hiveId])
  @@index([apiaryId])
  @@index([hiveId, date])
}

// Photo attached to a quick check
model QuickCheckPhoto {
  id           String     @id @default(uuid())
  quickCheckId String
  quickCheck   QuickCheck @relation(fields: [quickCheckId], references: [id], onDelete: Cascade)
  storageKey   String
  fileName     String
  mimeType     String
  fileSize     Int
  createdAt    DateTime   @default(now())

  @@index([quickCheckId])
}

// Share links for publicly sharing harvests/inspections
model ShareLink {
  id           String    @id @default(uuid())
  token        String    @unique
  resourceType String    // "HARVEST" or "INSPECTION"
  resourceId   String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([token])
  @@index([userId])
  @@index([resourceType, resourceId])
}

// Standalone photo attached to an apiary or hive
model Photo {
  id           String      @id @default(uuid())
  hiveId       String?
  hive         Hive?       @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  apiaryId     String
  apiary       Apiary      @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  inspectionId String?
  inspection   Inspection? @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  caption      String?     @db.Text
  storageKey   String
  fileName     String
  mimeType     String
  fileSize     Int
  date         DateTime    @default(now())
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  featureOfApiary Apiary? @relation("ApiaryFeaturePhoto")
  featureOfHive   Hive?   @relation("HiveFeaturePhoto")

  @@index([hiveId])
  @@index([apiaryId])
  @@index([inspectionId])
  @@index([hiveId, date])
}

// Document attached to an apiary or hive
model Document {
  id         String   @id @default(uuid())
  hiveId     String?
  hive       Hive?    @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  apiaryId   String
  apiary     Apiary   @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  title      String
  notes      String?  @db.Text
  storageKey String
  fileName   String
  mimeType   String
  fileSize   Int
  date       DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([hiveId])
  @@index([apiaryId])
  @@index([hiveId, date])
}

// Apiary sharing - membership for collaborative access
model ApiaryMember {
  id        String           @id @default(uuid())
  apiaryId  String
  apiary    Apiary           @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ApiaryRole
  status    MembershipStatus @default(PENDING)
  joinedAt  DateTime         @default(now())

  @@unique([apiaryId, userId])
  @@index([userId])
  @@index([apiaryId])
}

// Apiary sharing - invite links for joining an apiary
model ApiaryInvite {
  id        String     @id @default(uuid())
  token     String     @unique @default(uuid())
  apiaryId  String
  apiary    Apiary     @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  role      ApiaryRole // EDITOR or VIEWER
  createdBy String     // userId of the owner who created this invite
  expiresAt DateTime?
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())

  @@index([token])
  @@index([apiaryId])
}

// Long-lived API tokens for pull-based transcription/analysis workers
model WorkerToken {
  id          String    @id @default(uuid())
  name        String
  tokenHash   String    @unique
  prefix      String
  createdAt   DateTime  @default(now())
  createdById String
  createdBy   User      @relation("WorkerTokenCreator", fields: [createdById], references: [id], onDelete: Cascade)
  lastSeenAt  DateTime?
  revokedAt   DateTime?

  @@index([revokedAt])
}

// Platform metrics snapshot for admin observability
model PlatformMetricsSnapshot {
  id                  String   @id @default(uuid())
  date                DateTime @unique // One snapshot per day
  totalUsers          Int
  totalApiaries       Int
  totalHives          Int
  totalInspections    Int
  totalActions        Int
  totalQueens         Int
  totalHarvests       Int
  totalEquipmentItems Int
  activeUsers7Days    Int      // Users with activity in last 7 days
  activeUsers30Days   Int      // Users with activity in last 30 days
  weatherFetches24h      Int @default(0) // Weather API fetches in last 24h
  weatherFetchErrors24h  Int @default(0) // Weather fetch errors in last 24h
  createdAt           DateTime @default(now())

  @@index([date])
}

// AI assistant conversation threads (per-hive chat or apiary-level advisor)
model AssistantThread {
  id        String   @id @default(uuid())
  apiaryId  String // always set — drives ownership/authz
  hiveId    String? // null = apiary-scoped advisor; set = per-hive chat
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())
  apiary    Apiary   @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  hive      Hive?    @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  messages  AssistantMessage[]

  @@index([apiaryId])
  @@index([hiveId])
}

model AssistantMessage {
  id          String          @id @default(uuid())
  threadId    String
  role        AssistantRole // USER | ASSISTANT | SYSTEM
  content     String          @db.Text
  suggestions Json? // structured action proposals, nullable
  createdAt   DateTime        @default(now())
  thread      AssistantThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

enum AssistantRole {
  USER
  ASSISTANT
  SYSTEM
}

// Background job for full-account data export or import (per-user)
model AccountTransferJob {
  id                String                    @id @default(uuid())
  userId            String
  type              AccountTransferJobType
  status            AccountTransferJobStatus  @default(PENDING)
  createdAt         DateTime                  @default(now())
  startedAt         DateTime?
  finishedAt        DateTime?
  inputStorageKey   String?
  resultStorageKey  String?
  resultExpiresAt   DateTime?
  progress          String?
  errorMessage      String?                   @db.Text
  summary           Json?

  @@index([userId, type, status])
  @@index([status, startedAt])
  @@index([resultExpiresAt])
}

enum AccountTransferJobType {
  EXPORT
  IMPORT
}

enum AccountTransferJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
